# Backend production environment variables for EC2
SPRING_PROFILES_ACTIVE=prod
BACKEND_PORT=8080

# Database on the DB EC2 instance
SPRING_DATASOURCE_URL=jdbc:mysql://10.0.2.15:3306/book_village?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=bookvillage
SPRING_DATASOURCE_PASSWORD=change-me

# AWS S3
AWS_ACCESS_KEY=change-me
AWS_SECRET_KEY=change-me
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=book-village-prod-bucket
